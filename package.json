{
  "name": "melodist",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20 <25",
    "pnpm": "10.13.1"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "smoke:library": "node scripts/create-smoke-library.mjs",
    "smoke:verify-library": "node scripts/verify-smoke-library.mjs",
    "release:collect-assets": "node scripts/collect-release-assets.mjs",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.25",
    "@tauri-apps/api": "2.0.0",
    "@tauri-apps/plugin-dialog": "2.0.0",
    "@tauri-apps/plugin-global-shortcut": "2.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "2.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^6.0.1",
    "vitest": "^2.1.8"
  }
}
