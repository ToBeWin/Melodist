{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Melodist",
  "version": "0.1.0",
  "identifier": "ai.metapure.melodist",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Melodist",
        "width": 1240,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self'; connect-src ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/cover-cache/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "MetaPure Lab",
    "homepage": "https://metapure.ai",
    "category": "Music",
    "shortDescription": "Local-first private music player",
    "longDescription": "Melodist is a local-first desktop music player for private library playback, lyrics, cover art, and metadata.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "librsvg2-2"
        ]
      }
    }
  }
}
